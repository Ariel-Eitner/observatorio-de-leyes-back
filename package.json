{
  "name": "observatorio-de-leyes-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node --project tsconfig.json -r tsconfig-paths/register prisma/seed.ts",
    "db:setup": "npm run prisma:migrate && npm run prisma:seed",
    "audit": "ts-node --project tsconfig.json -r tsconfig-paths/register scripts/audit.ts",
    "audit:coverage": "ts-node --project tsconfig.json -r tsconfig-paths/register scripts/audit-coverage.ts",
    "audit:quality": "ts-node --project tsconfig.json -r tsconfig-paths/register scripts/audit-quality.ts",
    "audit:norm": "ts-node --project tsconfig.json -r tsconfig-paths/register scripts/audit-norm.ts",
    "tracking:e2e": "ts-node --project tsconfig.json -r tsconfig-paths/register scripts/tracking-e2e.ts",
    "tracking:e2e:docker": "ts-node --project tsconfig.json -r tsconfig-paths/register scripts/tracking-e2e.ts http://localhost:4000 http://localhost:4600/api"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.json prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.6.0",
    "@supabase/supabase-js": "^2.105.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "minisearch": "^7.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.30",
    "@types/ws": "^8.18.1",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "playwright": "^1.59.1",
    "prisma": "^6.6.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
