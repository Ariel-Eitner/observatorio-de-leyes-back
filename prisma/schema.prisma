generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TrackingEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  type       String
  sessionId  String   @map("session_id")
  guestId    String?  @map("guest_id")
  properties Json?
  context    Json?

  @@index([createdAt(sort: Desc)], map: "idx_te_created_at")
  @@index([guestId], map: "idx_te_guest")
  @@index([sessionId], map: "idx_te_session")
  @@index([type], map: "idx_te_type")
  @@index([type, createdAt(sort: Desc)], map: "idx_te_type_date")
  @@map("tracking_events")
}

model ExportGeneration {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  guestId   String   @map("guest_id")
  type      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([guestId, type], map: "export_generations_guest_type_idx")
  @@map("export_generations")
}

model PostDraft {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  platform      String   @default("twitter")
  postText      String   @map("post_text")
  commentText   String   @map("comment_text")
  lawId         String   @map("law_id")
  lawTitle      String   @map("law_title")
  articleNumber String   @map("article_number")
  utmContent    String   @map("utm_content")
  templateUsed  String   @map("template_used")
  hashtags      String   @default("")

  @@index([platform, createdAt(sort: Desc)], map: "idx_post_drafts_platform")
  @@map("post_drafts")
}

model PostedLawHistory {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lawId         String   @map("law_id")
  articleNumber String   @map("article_number")
  platform      String   @default("twitter")
  postedAt      DateTime @default(now()) @map("posted_at") @db.Timestamptz(6)

  @@index([lawId, articleNumber, platform], map: "idx_posted_history_lookup")
  @@map("posted_law_history")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model contact_submissions {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  nombre            String
  email             String
  tipo              String
  mensaje           String
  user_agent        String?
  is_read           Boolean  @default(false)
  apellido          String?
  telefono          String?
  profesion         String?
  utm_source        String?
  utm_medium        String?
  utm_campaign      String?
  utm_content       String?
  utm_term          String?
  empresa           String?
  provincia         String?
  como_nos_encontro String?
  tipo_usuario      String?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model founders {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime  @default(now()) @db.Timestamptz(6)
  nombre          String
  email           String    @unique
  canal           String?
  confirmed_at    DateTime? @db.Timestamptz(6)
  utm_source      String?
  utm_medium      String?
  utm_campaign    String?
  utm_content     String?
  utm_term        String?
  pagado          Boolean?  @default(false)
  comprobante_url String?
  comprobante_at  DateTime? @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model lead_events {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id    String    @db.Uuid
  type       String
  payload    Json?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  leads      leads     @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)])
  @@index([lead_id])
  @@index([type])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model leads {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String        @unique
  nombre            String?
  created_at        DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?     @default(now()) @db.Timestamptz(6)
  first_source      String        @default("unknown")
  status            String        @default("cold")
  utm_source        String?
  utm_medium        String?
  utm_campaign      String?
  utm_content       String?
  utm_term          String?
  notes             String?
  tipo_usuario      String?
  profesion         String?
  empresa           String?
  provincia         String?
  telefono          String?
  como_nos_encontro String?
  lead_events       lead_events[]

  @@index([created_at(sort: Desc)])
  @@index([first_source])
  @@index([provincia])
  @@index([status])
  @@index([tipo_usuario])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tracking_daily_summary {
  date          DateTime @id @db.Date
  sessions      Int      @default(0)
  guests        Int      @default(0)
  page_views    Int      @default(0)
  searches      Int      @default(0)
  zero_searches Int      @default(0)
  law_views     Int      @default(0)
  art_copies    Int      @default(0)
  amendments    Int      @default(0)
  inline_refs   Int      @default(0)
  contacts_sent Int      @default(0)
  errors_404    Int      @default(0)
  raw_total     Int      @default(0)
}

model Egreso {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fecha       DateTime @db.Date
  proveedor   String
  categoria   String   // INFRA | HERRAMIENTAS | HONORARIOS | PUBLICIDAD | EQUIPO | IMPUESTOS | OTRO
  descripcion String?
  monto       Float
  moneda      String   @default("USD") // ARS | USD
  tipoCambio  Float?   @map("tipo_cambio")
  montoArs    Float?   @map("monto_ars")
  comprobante String?
  estado      String   @default("pagado") // pagado | pendiente
  recurrente  Boolean  @default(false)
  mesesPagados String[] @default([]) @map("meses_pagados") // recurrentes: meses "YYYY-MM" marcados como pagados
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([fecha(sort: Desc)], map: "idx_egresos_fecha")
  @@index([categoria], map: "idx_egresos_categoria")
  @@map("egresos")
}

model Ingreso {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fecha       DateTime @db.Date
  tipo        String   // SUSCRIPCION | DONACION | SERVICIO | OTRO
  plan        String?
  cliente     String?
  descripcion String?
  monto       Float
  moneda      String   @default("USD") // ARS | USD
  tipoCambio  Float?   @map("tipo_cambio")
  montoArs    Float?   @map("monto_ars")
  medioCobro  String   @default("STRIPE") @map("medio_cobro") // MERCADOPAGO | STRIPE | TRANSFERENCIA | EFECTIVO | OTRO
  facturaAfip String?  @map("factura_afip")
  periodo     String?  // "2026-05"
  sourceRef   String?  @unique @map("source_ref") // dedupe de ingresos creados desde un pago
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([fecha(sort: Desc)], map: "idx_ingresos_fecha")
  @@index([tipo], map: "idx_ingresos_tipo")
  @@map("ingresos")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tweets_performance {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fecha           DateTime @db.Date
  tipo            String
  url             String?
  texto_preview   String?
  impresiones     Int      @default(0)
  replies         Int      @default(0)
  bookmarks       Int      @default(0)
  retweets        Int      @default(0)
  link_clicks     Int      @default(0)
  follows_ganados Int      @default(0)
  notas           String?
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  subtweets       Json     @default("[]")
}

// ─── Normas migradas a BD (molde: Constitución Nacional) ──────────────────────

model norms {
  id                String                   @id
  number            String?
  title             String
  common_name       String?
  summary           String?
  category          String?
  categories        String[]                 @default([])
  year              Int?
  sanction_date     DateTime?                @db.Date
  promulgation_date DateTime?                @db.Date
  publication_date  DateTime?                @db.Date
  effective_date    DateTime?                @db.Date
  derogated_date    DateTime?                @db.Date
  bo_number         String?
  short_code        String?
  aliases           String[]                 @default([])
  is_destacada      Boolean                  @default(false)
  infoleg_id_meta   String?
  status            String                   @default("VIGENTE")
  jurisdiction      String
  norm_type         String
  issuing_body      String?
  full_text         String?
  source_url        String?
  article_count     Int                      @default(0)
  executive_summary String?
  objective         String?
  problem_it_solves String?
  practical_impact  String?
  topics            String[]                 @default([])
  keywords          String[]                 @default([])
  related_norms     String[]                 @default([])
  affected_subjects String[]                 @default([])
  created_at        DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at        DateTime                 @default(now()) @db.Timestamptz(6)
  search            Unsupported("tsvector")? @default(dbgenerated("to_tsvector('spanish'::regconfig, ((((COALESCE(title, ''::text) || ' '::text) || COALESCE(common_name, ''::text)) || ' '::text) || COALESCE(summary, ''::text)))"))
  annexes           annexes[]
  articles          articles[]
  norm_amendments   norm_amendments[]
  norm_metadata     norm_metadata?
  norm_relations    norm_relations[]
  norm_sections     norm_sections[]
  norm_titles       norm_titles[]
  segments          segments[]

  @@index([keywords], map: "idx_norms_keywords", type: Gin)
  @@index([search], map: "idx_norms_search", type: Gin)
  @@index([status], map: "idx_norms_status")
  @@index([topics], map: "idx_norms_topics", type: Gin)
  @@index([norm_type], map: "idx_norms_type")
}

model norm_metadata {
  norm_id          String   @id
  main_topic       String?
  subtopics        String[] @default([])
  related_laws     String[] @default([])
  regulations      String[] @default([])
  modifying_norms  String[] @default([])
  derogating_norms String[] @default([])
  jurisprudence    String[] @default([])
  doctrine         String[] @default([])
  obligations      String[] @default([])
  rights           String[] @default([])
  sanctions        String[] @default([])
  use_cases        String[] @default([])
  faq              Json?
  norms            norms    @relation(fields: [norm_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model norm_sections {
  id            String        @id
  norm_id       String
  number        String?
  name          String
  article_start Int?
  article_end   Int?
  ord           Float         @default(0)
  norms         norms         @relation(fields: [norm_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  norm_titles   norm_titles[]

  @@index([norm_id], map: "idx_sections_norm")
}

model norm_titles {
  id            String        @id
  section_id    String
  norm_id       String
  number        String?
  name          String
  article_start Int?
  article_end   Int?
  ord           Float         @default(0)
  norms         norms         @relation(fields: [norm_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  norm_sections norm_sections @relation(fields: [section_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([section_id], map: "idx_titles_section")
}

model articles {
  id                         String                   @id
  norm_id                    String
  number                     String
  title                      String?
  body                       String
  plain_language_explanation String?
  ord                        Float                    @default(0)
  status                     String?
  effective_date             DateTime?                @db.Date
  derogated_date             DateTime?                @db.Date
  practical_effects          String[]                 @default([])
  examples                   String[]                 @default([])
  related_articles           String[]                 @default([])
  jurisprudence              String[]                 @default([])
  regulations                String[]                 @default([])
  keywords                   String[]                 @default([])
  jurisprudence_refs         Json?
  visual_content             Json?
  search                     Unsupported("tsvector")? @default(dbgenerated("to_tsvector('spanish'::regconfig, ((((COALESCE(title, ''::text) || ' '::text) || body) || ' '::text) || COALESCE(plain_language_explanation, ''::text)))"))
  article_amendments         article_amendments[]
  norms                      norms                    @relation(fields: [norm_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  segments                   segments[]

  @@index([norm_id], map: "idx_articles_norm")
  @@index([search], map: "idx_articles_search", type: Gin)
}

model segments {
  id                String   @id
  article_id        String
  norm_id           String
  article_number    String?
  segment_type      String
  body              String
  plain_explanation String?
  practical_example String?
  refs              String[] @default([])
  ord               Float    @default(0)
  articles          articles @relation(fields: [article_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  norms             norms    @relation(fields: [norm_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([article_id], map: "idx_segments_article")
  @@index([norm_id], map: "idx_segments_norm")
}

model article_amendments {
  id             String    @id
  article_id     String
  modifying_law  String?
  modifying_date DateTime? @db.Date
  previous_text  String?
  new_text       String?
  description    String?
  created_at     DateTime? @db.Timestamptz(6)
  articles       articles  @relation(fields: [article_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([article_id], map: "idx_art_amend_article")
}

model norm_amendments {
  id             String    @id
  norm_id        String
  modifying_law  String?
  modifying_date DateTime? @db.Date
  description    String
  type           String?
  created_at     DateTime? @db.Timestamptz(6)
  norms          norms     @relation(fields: [norm_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([norm_id], map: "idx_norm_amend_norm")
}

model annexes {
  id      String  @id
  norm_id String
  number  String?
  title   String?
  content String
  ord     Float   @default(0)
  norms   norms   @relation(fields: [norm_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([norm_id], map: "idx_annexes_norm")
}

model norm_relations {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source_id    String
  target_id    String
  type         String
  description  String?
  target_label String?
  norms        norms   @relation(fields: [source_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([source_id, target_id, type])
  @@index([source_id], map: "idx_relations_source")
  @@index([target_id], map: "idx_relations_target")
}

// Normas referenciadas pero NO cargadas en detalle. Hacen clickeables las
// referencias inline (nombre completo + link a InfoLeg) sin cargar el articulado.
// Antes vivían hardcodeadas en src/data/norm-stubs.ts (+ espejo en el front).
model norm_stubs {
  number     String   @id
  name       String
  infoleg_id String?
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("norm_stubs")
}

// Categorías temáticas (slug, etiqueta, descripción, icono). Antes estaban
// duplicadas y divergentes: CATEGORY_LABELS en laws.service (back) y CATEGORIES
// en app/lib/categories.ts (front). Fuente única ahora.
model categories {
  slug        String   @id
  label       String
  description String?
  icon        String?
  ord         Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@map("categories")
}
